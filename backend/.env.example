# Database Configuration
# PostgreSQL connection string (required)
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://user:password@localhost:5432/team_task_manager"

# JWT Configuration (required)
# Secret key for signing JWT tokens - MUST be changed in production
JWT_SECRET="your-secret-key-here-change-in-production"

# JWT token expiration times (required)
# Access token: short-lived token for API requests (e.g., "15m", "1h")
ACCESS_TOKEN_EXPIRY="15m"

# Refresh token: long-lived token for obtaining new access tokens (e.g., "7d", "30d")
REFRESH_TOKEN_EXPIRY="7d"

# Server Configuration
# Port number for the server (default: 5000)
PORT=5000

# Node environment (development, production, test)
NODE_ENV="development"

# CORS Configuration
# Frontend URL for CORS policy (required for production)
FRONTEND_URL="http://localhost:5173"
